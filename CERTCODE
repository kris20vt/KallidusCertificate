<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=ISO-8859-1" />
    <title>Lesson Certificate</title>
    <style type="text/css">
        /* RESET & PDF DEFAULTS */
        body {
            margin: 0;
            padding: 0;
            background-color: #ffffff;
            font-family: 'Helvetica', 'Arial', sans-serif;
            font-size: 20pt;
            text-align: center;
        }

        /* BACKGROUND CONTAINER 
           If using a custom background image, uncomment the line below 
           and replace the URL. Suggested size: 1240 x 1754 pixels.
        */
        .certificate-wrapper {
            width: 1100px; /* Standard width for Kallidus PDF rendering */
            height: 780px;
            margin: 0 auto;
            border: 20px solid #1a3d6d; /* Dark Blue Border */
            padding: 40px;
            position: relative;
            background-color: #fff;
            /* background-image: url("YOUR_BACKGROUND_URL_HERE"); */
            background-size: cover;
        }

        /* LOGO - Requirements: 250x80 pixels */
        .logo {
            margin-top: 20px;
            height: 80px;
        }
        .logo img {
            width: 250px;
            height: 80px;
        }

        /* TEXT STYLING */
        .title {
            font-size: 45pt;
            color: #1a3d6d;
            margin-top: 50px;
            font-weight: bold;
            text-transform: uppercase;
        }

        .subtitle {
            font-size: 18pt;
            color: #666;
            margin-top: 20px;
        }

        .user-name {
            font-size: 38pt;
            font-weight: bold;
            color: #000;
            margin: 40px 0;
            padding-bottom: 10px;
            border-bottom: 3px solid #1a3d6d;
            display: inline-block;
            min-width: 600px;
        }

        .lesson-title {
            font-size: 24pt;
            font-style: italic;
            color: #1a3d6d;
            margin: 20px 0;
        }

        /* FOOTER / SIGNATURES */
        .footer {
            position: absolute;
            bottom: 80px;
            width: 100%;
            left: 0;
        }

        .date-box {
            font-size: 14pt;
            margin-bottom: 20px;
        }

        .signature-row {
            display: flex;
            justify-content: space-around;
            padding: 0 100px;
        }

        .sig-line {
            border-top: 1px solid #333;
            width: 250px;
            font-size: 12pt;
            padding-top: 10px;
            color: #333;
        }
    </style>
</head>
<body>

    <div class="certificate-wrapper">
        
        <div class="logo">
            <img src="https://via.placeholder.com/250x80?text=Your+Logo+Here" alt="Company Logo" />
        </div>

        <div class="title">Certificate of Completion</div>
        
        <div class="subtitle">This is to certify that</div>

        <div class="user-name">
            [UserFullName]
        </div>

        <div class="subtitle">has successfully completed the lesson:</div>
        
        <div class="lesson-title">
            [LessonTitle]
        </div>

        <div class="footer">
            <div class="date-box">
                Completed on: [DateCompleted]
            </div>

            <div class="signature-row">
                <div class="sig-line">Training Department</div>
                <div class="sig-line">Course Instructor</div>
            </div>
        </div>

    </div>

</body>
</html>

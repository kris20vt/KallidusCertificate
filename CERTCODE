<html>
  <head>
    <meta content="text/html; charset=ISO-8859-1" http-equiv="content-type" />
    <title>Lesson Certificate</title>
    <style type="text/css">
      /* Add your logo here, dimensions should be 250 x 80 pixels */
      .logoImage {
        background-image: url("https://drive.google.com/file/d/1PEgfxnVnG7TM-CH8FQ8R5D5MgEhe8Crs/view?usp=sharing");
      }
      /* Add your image URL below and uncomment the section to add a custom background
      It is recommended your image be 1240 x 1754 pixels in size */
      /*
        .backgroundImage {
            background-image: url("")
        }
      */

      /* Add any custom fonts to the start of the list below */
      .fontStyles {
        font-family: 'Helvetica', 'Arial', 'sans-serif';
      }

      body {
        font-size: 25pt;
        background-image: url("data:image/png;base64,");
		color: #565555;

        background-color: white;
        text-align: center;
        padding: 110px 0px 40px 0px;
        background-size: contain;
        background-position: center 0px;
        background-repeat: no-repeat;
      }

      .logo {
        width: 250px;
        height: 80px;
        background-repeat: no-repeat;
        display: inline-block;
        padding-bottom: 10em;
      }

      h1 {
        color: #000000;
        font-size: 35px;
        font-weight: normal;
        margin: 20px 0px 40px 0px;
        padding-bottom: 8px;
      }

      h2 {
        font-size: 30px;
        padding: 10px 0px 20px 0px;
      }

      h3 {
        color: #000000;
        font-size: 28px;
        font-weight: normal;
      }

      p {
        font-size: 20px;
        font-weight: bold;
      }

      div.A4Page {
        display: table;
        text-align: center;
        width: 21cm;
        height: 32.36cm;
        margin: auto;
      }

      div.centered {
        display: table-cell;
        vertical-align: top;
      }

      span {
        display: none;
      }

      span.unhide {
        display: inline;
      }
    </style>
  </head>
  <body class="backgroundImage fontStyles">
    <div class="A4Page">
      <div class="centered">
        <div class="logo logoImage"></div>
        <h2>This is to certify that</h2>
        <h1>%UserFirstName% %UserLastName%</h1>
        <p>has successfully completed</p>
        <h3>%LessonTitle%</h3>
        <p></p>
        <h3></h3>
        <p>
          <!-- Set of lesson types: span's are hidden by default; the one to be displayed has 'class="unhide"' added at runtime -->
          <span id="%ShowIfInstructorLed%">classroom learning</span>
          <span id="%ShowIfELearning%">courses</span>
          <span id="%ShowIfBook%">book</span>
          <span id="%ShowIfAudio%">audio</span>
          <span id="%ShowIfVideo%">video</span>
          <span id="%ShowIfContainer%">learning</span>
          <span id="%ShowIfOther%">learning</span>
          <span id="%ShowIfUndefined%">learning</span>
          on
        </p>
        <h3>%LessonDate%</h3>
        <!-- Set of CPD points words: span's are hidden by default; the one to be displayed has 'class="unhide"' added at runtime -->
        <span id="%ShowIfCPD%">
          <p>
            this is worth %CPDPoints% CPD
            <span id="%ShowIfOnePoint%">hour</span>
            <span id="%ShowIfNotOnePoint%">hours</span>
          </p>
        </span>
      </div>
    </div>
  </body>
</html>
